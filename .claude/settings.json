{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(ls:*)",
      "Bash(pnpm:*)",
      "WebFetch(domain:astro-tips.dev)",
      "WebFetch(domain:developers.cloudflare.com)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git push:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(wrangler tail:*)",
      "Bash(wrangler deployments:*)",
      "Bash(wrangler versions:*)",
      "Skill(playwright-cli)",
      "Skill(branch-start)",
      "Skill(branch-preview)",
      "Skill(commit-commands:commit-push-pr)",
      "Bash(gh issue:*)",
      "WebFetch(domain:blog.gensobunya.net)",
      "Bash(playwright-cli open:*)",
      "Bash(playwright-cli screenshot:*)",
      "Bash(playwright-cli scroll:*)",
      "Bash(playwright-cli mousewheel:*)",
      "Bash(playwright-cli close:*)",
      "mcp__astro-docs__search_astro_docs",
      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:astro.build)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh pr:*)",
      "Skill(commit-commands:commit)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint:fix",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint:fix",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "code-review@claude-plugins-official": true
  }
}
