{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(ls:*)",
      "Bash(pnpm:*)",
      "WebFetch(domain:astro-tips.dev)",
      "WebFetch(domain:developers.cloudflare.com)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git push:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(wrangler tail:*)",
      "Bash(wrangler deployments:*)",
      "Bash(wrangler versions:*)",
      "Skill(playwright-cli)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint:fix && pnpm format",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint:fix && pnpm format",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  }
}
