---
export const prerender = true
import { type CollectionEntry, getCollection, render } from "astro:content"
import MdxA from "@components/mdx/MdxA.astro"
import MdxBlockQuote from "@components/mdx/MdxBlockQuote.astro"
import MdxH2 from "@components/mdx/MdxH2.astro"
import MdxH3 from "@components/mdx/MdxH3.astro"
import MdxH4 from "@components/mdx/MdxH4.astro"
import MdxPicture from "@components/mdx/MdxPicture.astro"
import MdxStrong from "@components/mdx/MdxStrong.astro"
import MdxTable from "@components/mdx/MdxTable.astro"
import BlogPost from "@layouts/BlogPost.astro"
import { extractDescription } from "@lib/extractDescription"
import { slugFromId } from "@lib/postSlug"
import type { GetStaticPaths } from "astro"

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection("post")
  return posts.map((post) => ({
    params: { slug: slugFromId(post.id) },
    props: post
  }))
}
type Props = CollectionEntry<"post">

const post = Astro.props
const { Content, headings } = await render(post)

// post.body から description を抽出（Container APIを使わず）
const description = extractDescription(post.body ?? "")
---

<BlogPost {...post} description={description} headings={headings}>
  <Content
    components={{
      h2: MdxH2,
      h3: MdxH3,
      h4: MdxH4,
      blockquote: MdxBlockQuote,
      a: MdxA,
      table: MdxTable,
      strong: MdxStrong,
      img: MdxPicture
    }}
  />
</BlogPost>
