---
import { STOREFRONT_LINKS } from "~/consts"

const externalLinkIcon =
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="0.85em" height="0.85em" class="opacity-80" aria-hidden="true"><path fill="currentColor" d="M14 3v2h3.59l-9.83 9.83l1.41 1.41L19 6.41V10h2V3m-2 16H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2z"/></svg>'
---

<div
  class="not-prose overflow-hidden rounded-lg border border-stone-200 bg-white p-4 shadow-xs md:p-5"
>
  <div class="mb-3 text-sm font-bold leading-tight text-stone-800 md:text-base">
    愛用機材リスト
  </div>
  <div class="mb-4 text-xs leading-relaxed text-secondary md:text-sm">
    ブログで紹介した機材・アクセサリーのうち、現在使っている製品をジャンル別にまとめています
  </div>
  <div class="flex flex-wrap gap-2.5">
    {
      STOREFRONT_LINKS.map((link) => (
        <a
          href={link.url}
          class:list={[
            "inline-flex items-center gap-1.5 rounded-md px-3.5 py-2 text-xs font-bold text-white no-underline hover:opacity-90 md:text-sm",
            link.colorClass
          ]}
          target="_blank"
          rel="sponsored noopener noreferrer"
        >
          <Fragment set:html={link.iconSvg} />
          {link.label}
          <Fragment set:html={externalLinkIcon} />
        </a>
      ))
    }
  </div>
</div>
