---
import { Picture } from "astro:assets"
import logo from "../images/dummy.jpg"
import { STOREFRONT_LINKS } from "~/consts"
import { Content as AboutText } from "./text/about.md"
---

<div class="my-8 rounded-lg border border-gray-200 bg-white p-6">
  <div class="flex flex-col items-center md:flex-row">
    <div
      class="mb-4 size-32 shrink-0 overflow-hidden rounded-full md:mb-0 md:mr-6"
    >
      <Picture
        src={logo}
        alt="著者アイコン"
        class="size-full object-cover"
        fallbackFormat="jpg"
      />
    </div>
    <div>
      <div
        class="prose prose-sm max-w-none text-sm leading-relaxed text-gray-600 md:prose-base"
      >
        <AboutText />
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        {
          STOREFRONT_LINKS.map((link) => (
            <a
              href={link.url}
              class:list={[
                "inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-sm font-bold text-white no-underline hover:opacity-90",
                link.colorClass
              ]}
              target="_blank"
              rel="sponsored noopener noreferrer"
            >
              <Fragment set:html={link.iconSvg} />
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
