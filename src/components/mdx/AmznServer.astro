---
import { env } from "cloudflare:workers"
import {
  createAmazonAdapter,
  createKVCacheAdapter,
  createSlackLoggerAdapter
} from "../../server/adapters/amazonAdapter"
import { isValidAsin } from "../../server/domain/validators"
import { linkCardBadge, linkCardFrame, linkCardPrice } from "./cardStyles"

interface Props {
  asin: string
}

const { asin } = Astro.props

if (!isValidAsin(asin)) {
  throw new Error("asin must be 10 characters of uppercase letters and numbers")
}

const fallbackUrl = `https://www.amazon.co.jp/dp/${asin}`

let productTitle = "Amazon.co.jp"
let productImageUrl: string | undefined
let productUrl = fallbackUrl
let brandName: string | undefined
let priceDisplay: string | undefined
let savingsPercentage: number | undefined
let loyaltyPoints: number | undefined

try {
  if (
    env.PAAPI_DATASTORE &&
    env.CREATORS_CREDENTIAL_ID &&
    env.CREATORS_CREDENTIAL_SECRET &&
    env.PARTNER_TAG
  ) {
    const cache = createKVCacheAdapter(env.PAAPI_DATASTORE)
    const logger = createSlackLoggerAdapter(env.SLACK_WEBHOOK_URL ?? "")
    const adapter = createAmazonAdapter({
      cache,
      config: {
        credentialId: env.CREATORS_CREDENTIAL_ID,
        credentialSecret: env.CREATORS_CREDENTIAL_SECRET,
        credentialVersion: "2.3",
        partnerTag: env.PARTNER_TAG,
        marketplace: "www.amazon.co.jp"
      },
      logger,
      kv: env.PAAPI_DATASTORE
    })

    // キャッシュ確認 → API取得
    let data = await adapter.getCached(asin)
    if (!data) {
      data = await adapter.getProductInfo(asin)
      await adapter.cacheResult(asin, data)
    }

    const product = data.itemsResult?.items?.[0]
    if (product) {
      productTitle = product.itemInfo?.title?.displayValue ?? "Amazon.co.jp"
      productImageUrl =
        product.images?.primary?.large?.url ??
        product.images?.primary?.medium?.url
      productUrl = product.detailPageURL ?? fallbackUrl

      const byLine = product.itemInfo?.byLineInfo
      brandName =
        byLine?.brand?.displayValue ??
        byLine?.manufacturer?.displayValue ??
        byLine?.contributors?.[0]?.name

      const listing =
        product.offersV2?.listings?.find((l) => l.isBuyBoxWinner) ??
        product.offersV2?.listings?.[0]
      if (listing) {
        priceDisplay = listing.price?.money?.displayAmount
        savingsPercentage = listing.price?.savings?.percentage
        loyaltyPoints = listing.loyaltyPoints?.points
      }
    }
  }
} catch (e) {
  console.error(`Amzn fetch failed for ASIN ${asin}:`, e)
}
---

<a
  href={productUrl}
  class="no-underline hover:opacity-90"
  target="_blank"
  rel="noopener noreferrer"
>
  <div class={linkCardFrame}>
    <div class="flex min-w-0 flex-1 flex-col justify-center p-2">
      <div class={`${linkCardBadge} text-amazon`}>Amazon</div>
      <div
        class="line-clamp-2 text-sm font-bold leading-tight text-stone-800 md:text-base"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="1em"
          height="1em"
          class="inline"
          aria-hidden="true"
          ><path
            fill="currentColor"
            d="M14 3v2h3.59l-9.83 9.83l1.41 1.41L19 6.41V10h2V3m-2 16H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2z"
          ></path></svg
        >
        {productTitle}
      </div>
      {
        brandName && (
          <div class="mt-0.5 truncate text-xs text-secondary">{brandName}</div>
        )
      }
      {
        priceDisplay && (
          <div class="mt-1 flex flex-wrap items-baseline gap-x-2">
            <span class={linkCardPrice}>{priceDisplay}</span>
            {savingsPercentage && (
              <span class="text-xs text-error font-medium">
                {savingsPercentage}%OFF
              </span>
            )}
            {loyaltyPoints && (
              <span class="text-xs text-primary font-medium">
                +{loyaltyPoints}pt
              </span>
            )}
          </div>
        )
      }
      <div class="mt-1 text-xs text-secondary md:text-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="1em"
          height="1em"
          class="inline"
          aria-hidden="true"
          ><path
            fill="currentColor"
            d="M16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2m-5.15 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 0 1-4.33 3.56M14.34 14H9.66c-.1-.66-.16-1.32-.16-2s.06-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2M12 19.96c-.83-1.2-1.5-2.53-1.91-3.96h3.82c-.41 1.43-1.08 2.76-1.91 3.96M8 8H5.08A7.92 7.92 0 0 1 9.4 4.44C8.8 5.55 8.35 6.75 8 8m-2.92 8H8c.35 1.25.8 2.45 1.4 3.56A8 8 0 0 1 5.08 16m-.82-2C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2M12 4.03c.83 1.2 1.5 2.54 1.91 3.97h-3.82c.41-1.43 1.08-2.77 1.91-3.97M18.92 8h-2.95a15.7 15.7 0 0 0-1.38-3.56c1.84.63 3.37 1.9 4.33 3.56M12 2C6.47 2 2 6.5 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2"
          ></path></svg
        >
        Amazon.co.jp
      </div>
    </div>
    <div class="flex w-[25%] shrink-0 items-center justify-center p-2">
      {
        productImageUrl && (
          <figure class="flex items-center justify-center">
            <img
              src={productImageUrl}
              class="max-h-24 w-auto object-contain md:max-h-32"
              alt="Amazon商品画像"
              loading="lazy"
            />
          </figure>
        )
      }
    </div>
  </div>
</a>
