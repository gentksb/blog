---
import { env } from "cloudflare:workers"
import { createOgpKVCacheAdapter } from "../../server/adapters/ogpAdapter"
import { getOgpMetaData } from "../../server/services/getOgpMetaData"
import { isValidUrl } from "../../server/domain/validators"

interface Props {
  url: string
  linkUrl?: string
}

const { url, linkUrl } = Astro.props

// URLバリデーション（HTTP(S)スキームのみ許可）
if (!isValidUrl(url) || (linkUrl !== undefined && !isValidUrl(linkUrl))) {
  throw new Error("Invalid URL: must be HTTP(S)")
}

const targetUrl = linkUrl ?? url

// ブランドテーマ判定
const brandTheme = url.includes("yahoo.co.jp")
  ? "yahoo"
  : url.includes("rakuten.co.jp")
    ? "rakuten"
    : null

const brandColorBorder: Record<string, string> = {
  amazon: "border-amazon border-3",
  rakuten: "border-rakuten border-3",
  yahoo: "border-yahoo border-3"
}
const brandColorBackground: Record<string, string> = {
  amazon: "bg-amazon",
  rakuten: "bg-rakuten",
  yahoo: "bg-yahoo"
}

// OGPデータ取得（KVキャッシュ付き）
let ogpTitle: string = url
let ogpDescription: string = ""
let ogpSiteName: string = ""
let ogpImageUrl: string | undefined = undefined

try {
  if (env.OGP_DATASTORE) {
    const cache = createOgpKVCacheAdapter(env.OGP_DATASTORE)

    // キャッシュ確認
    const cached = await cache.get(url)
    let ogpData = null

    if (cached && typeof cached === "object") {
      ogpData = cached
    } else {
      // キャッシュミス → 取得してキャッシュ保存
      ogpData = await getOgpMetaData(url, env)
      if (ogpData.ok) {
        await cache.put(url, ogpData)
      }
    }

    if (ogpData && ogpData.ok) {
      ogpTitle = ogpData.ogpTitle ?? url
      ogpDescription = ogpData.ogpDescription ?? ""
      ogpSiteName = ogpData.ogpSiteName ?? ""
      // 外部ドメインはCloudflare Image Resizingでプロキシできないため、HTTP(S)のみ許可
      ogpImageUrl = isValidUrl(ogpData.ogpImageUrl ?? "")
        ? ogpData.ogpImageUrl
        : undefined
    }
  }
} catch (e) {
  console.error(`LinkCard OGP fetch failed for ${url}:`, e)
}

const parsedTargetUrl = new URL(targetUrl)
const isExternal = parsedTargetUrl.hostname !== "blog.gensobunya.net"
---

<a
  href={targetUrl}
  class="hover:underline"
  target="_blank"
  rel="noopener noreferrer"
>
  <div
    class={`not-prose relative mx-2 mt-2 flex overflow-hidden rounded-lg border bg-white shadow-sm ${brandTheme ? brandColorBorder[brandTheme] : "border-stone-200"}`}
  >
    <div class="flex flex-1 flex-col justify-center p-2 min-w-0">
      {
        brandTheme && (
          <div
            class={`absolute right-0 top-0 ${brandColorBackground[brandTheme]} rounded-bl px-2 py-1 text-xs text-white`}
          >
            {brandTheme.charAt(0).toUpperCase() + brandTheme.slice(1)}
          </div>
        )
      }
      <div
        class="line-clamp-2 text-sm font-bold leading-none text-stone-800 md:text-base"
      >
        {
          isExternal && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="1em"
              height="1em"
              class="inline"
              aria-hidden="true"
            >
              <path
                fill="currentColor"
                d="M14 3v2h3.59l-9.83 9.83l1.41 1.41L19 6.41V10h2V3m-2 16H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2z"
              />
            </svg>
          )
        }
        {ogpTitle}
      </div>
      <div
        class="mt-1 line-clamp-2 max-h-[3em] text-xs font-normal text-secondary md:text-sm"
      >
        {ogpDescription}
      </div>
      <div class="mt-1 text-xs text-secondary md:text-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="1em"
          height="1em"
          class="inline"
          aria-hidden="true"
          ><path
            fill="currentColor"
            d="M16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2m-5.15 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 0 1-4.33 3.56M14.34 14H9.66c-.1-.66-.16-1.32-.16-2s.06-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2M12 19.96c-.83-1.2-1.5-2.53-1.91-3.96h3.82c-.41 1.43-1.08 2.76-1.91 3.96M8 8H5.08A7.92 7.92 0 0 1 9.4 4.44C8.8 5.55 8.35 6.75 8 8m-2.92 8H8c.35 1.25.8 2.45 1.4 3.56A8 8 0 0 1 5.08 16m-.82-2C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2M12 4.03c.83 1.2 1.5 2.54 1.91 3.97h-3.82c.41-1.43 1.08-2.77 1.91-3.97M18.92 8h-2.95a15.7 15.7 0 0 0-1.38-3.56c1.84.63 3.37 1.9 4.33 3.56M12 2C6.47 2 2 6.5 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2"
          ></path></svg
        >
        {ogpSiteName}
      </div>
    </div>
    <div class="max-h-28 w-[30%] flex-shrink-0 md:max-h-36">
      {
        ogpImageUrl && (
          <figure class="flex h-full justify-end">
            <img
              src={ogpImageUrl}
              class="h-full w-auto"
              alt="リンク先カバー画像"
              loading="lazy"
            />
          </figure>
        )
      }
    </div>
  </div>
</a>
