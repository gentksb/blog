---
import { getIndentClass } from "@lib/headings"
import type { MarkdownHeading } from "astro"

interface Props {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props

// h2とh3のみを表示
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3)

if (filteredHeadings.length === 0) {
  return null
}
---

<details class="mb-6 rounded-lg border border-gray-200 bg-white">
  <summary
    class="cursor-pointer px-4 py-3 text-base font-medium select-none"
    id="mobile-toc-heading"
  >
    目次
  </summary>
  <div class="px-4 pb-4" id="mobile-toc">
    <nav class="toc-nav" aria-labelledby="mobile-toc-heading">
      <ul class="space-y-2 text-sm">
        {
          filteredHeadings.map((heading) => (
            <li class={getIndentClass(heading.depth)}>
              <a
                href={`#${heading.slug}`}
                class="rounded text-gray-600 hover:text-primary hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
              >
                {heading.text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</details>
