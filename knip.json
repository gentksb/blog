{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/pages/**/*.{astro,ts,tsx}", "src/layouts/**/*.astro"],
  "project": ["src/**/*.{ts,tsx,astro}"],
  "ignore": ["src/content/**", "**/*.d.ts", "dist/**", "node_modules/**"],
  "ignoreFiles": [
    "src/components/mdx/Amzn.astro",
    "src/components/mdx/AmznServer.astro",
    "src/components/mdx/LinkCard.astro",
    "src/components/mdx/LinkCardServer.astro",
    "src/components/mdx/SimpleLinkCard.astro",
    "src/components/mdx/PositiveBox.astro",
    "src/components/mdx/NegativeBox.astro"
  ],
  "ignoreDependencies": [
    "@iconify-json/mdi",
    "@cloudflare/pages-plugin-vercel-og",
    "cloudflare",
    "textlint",
    "@textlint-ja/textlint-rule-no-filler",
    "textlint-rule-ja-no-abusage",
    "textlint-rule-ja-no-redundant-expression",
    "textlint-rule-no-doubled-conjunction",
    "textlint-rule-no-doubled-conjunctive-particle-ga",
    "textlint-rule-no-doubled-joshi",
    "textlint-rule-no-dropping-the-ra",
    "textlint-rule-no-hankaku-kana",
    "textlint-rule-no-mix-dearu-desumasu",
    "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet",
    "textlint-rule-no-todo",
    "textlint-rule-preset-jtf-style"
  ],
  "ignoreExportsUsedInFile": true
}
